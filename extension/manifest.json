{
    "manifest_version": 3,
    "name": "ChobShop FB Group Poster",
    "version": "11.0",
    "description": "ช่วยโพสต์สินค้าจาก ChobShop ลง Facebook Group ได้อย่างรวดเร็ว พร้อมระบบ Auto-Post",
    "icons": {
        "16": "app-icon.png",
        "48": "app-icon.png",
        "128": "app-icon.png"
    },
    "permissions": [
        "storage",
        "clipboardRead",
        "clipboardWrite",
        "alarms",
        "tabs",
        "activeTab",
        "scripting",
        "sidePanel"
    ],
    "side_panel": {
        "default_path": "popup.html"
    },
    "action": {
        "default_icon": {
            "16": "app-icon.png",
            "48": "app-icon.png",
            "128": "app-icon.png"
        }
    },
    "host_permissions": [
        "https://*.vercel.app/*",
        "http://localhost:*/*",
        "https://*.shopee.co.th/*",
        "https://*.susercontent.com/*",
        "https://*.facebook.com/*",
        "https://chob.shop/*"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "content_scripts": [
        {
            "matches": [
                "https://*.facebook.com/*"
            ],
            "js": [
                "content.js"
            ]
        }
    ]
}