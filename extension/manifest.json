{
    "manifest_version": 3,
    "name": "ChobShop FB Group Poster",
    "version": "2.0",
    "description": "ช่วยโพสต์สินค้าจาก ChobShop ลง Facebook Group ได้อย่างรวดเร็ว พร้อมระบบ Auto-Post",
    "permissions": [
        "storage",
        "clipboardRead",
        "clipboardWrite",
        "alarms",
        "tabs",
        "activeTab"
    ],
    "host_permissions": [
        "https://*.vercel.app/*",
        "http://localhost:*/*",
        "https://*.shopee.co.th/*",
        "https://*.facebook.com/*",
        "https://chob.shop/*"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "action": {
        "default_popup": "popup.html",
        "default_icon": {
            "16": "icons/icon16.png",
            "48": "icons/icon48.png",
            "128": "icons/icon128.png"
        }
    },
    "content_scripts": [
        {
            "matches": [
                "https://*.facebook.com/*"
            ],
            "js": [
                "content.js"
            ]
        }
    ]
}