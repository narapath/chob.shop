# === Chob.Shop Social Media API Configuration ===
# Copy this file to ".env" and fill in your actual API keys.
# NEVER commit your .env file to version control!

# --- Facebook Page ---
# Get these from https://developers.facebook.com/
# You need a Page Access Token with pages_manage_posts permission.
FB_PAGE_ID=your_facebook_page_id
FB_PAGE_ACCESS_TOKEN=your_facebook_page_access_token

# --- Instagram Business Account ---
# Uses the same Meta/Facebook Graph API.
# You need an IG User Access Token with instagram_content_publish permission.
# Your IG account must be a Business or Creator account linked to a Facebook Page.
IG_USER_ID=your_instagram_user_id
IG_ACCESS_TOKEN=your_instagram_access_token

# --- X (Twitter) ---
# Get these from https://developer.x.com/en/portal/dashboard
# You need OAuth 1.0a keys with Read and Write permissions.
X_API_KEY=your_x_api_key
X_API_SECRET=your_x_api_secret
X_ACCESS_TOKEN=your_x_access_token
X_ACCESS_TOKEN_SECRET=your_x_access_token_secret

# --- Google Indexing API ---
# Get this from Google Cloud Console > Service Accounts > Create Key (JSON)
# Paste the ENTIRE JSON content as a single line
# Don't forget to: 1) Enable Indexing API  2) Add the service account email as Owner in Search Console
GOOGLE_SERVICE_ACCOUNT_JSON=

# --- Your Website URL (used in social posts) ---
SITE_URL=http://localhost:3000
